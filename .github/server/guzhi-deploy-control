#!/usr/bin/env bash
set -Eeuo pipefail

SERVICE_NAME="guzhi-assistant.service"
LEGACY_SERVICE_NAME="xiaobaiyangji.service"
PORT="7084"
APP_DLL_PGREP="/www/wwwroot/小白养基/[小]白养基.dll"

cmd="${1:-}"
arg="${2:-}"

case "$cmd" in
  daemon-reload)
    systemctl daemon-reload
    ;;
  enable)
    systemctl enable "$SERVICE_NAME" >/dev/null
    ;;
  start)
    systemctl disable --now "$LEGACY_SERVICE_NAME" 2>/dev/null || true
    systemctl start "$SERVICE_NAME"
    ;;
  stop)
    systemctl stop "$SERVICE_NAME" || true
    ;;
  restart)
    systemctl restart "$SERVICE_NAME"
    ;;
  status)
    systemctl status "$SERVICE_NAME" --no-pager
    ;;
  is-active)
    systemctl is-active "$SERVICE_NAME" || true
    ;;
  logs)
    journalctl -u "$SERVICE_NAME" -n "${arg:-160}" --no-pager
    ;;
  port-info)
    ss -lntp | grep ":${PORT}" || true
    ;;
  port-in-use)
    ss -lntp | grep -q ":${PORT}"
    ;;
  release-port)
    systemctl disable --now "$LEGACY_SERVICE_NAME" 2>/dev/null || true
    systemctl reset-failed "$LEGACY_SERVICE_NAME" 2>/dev/null || true
    systemctl stop "$SERVICE_NAME" || true
    systemctl kill --kill-who=all "$SERVICE_NAME" 2>/dev/null || true
    systemctl reset-failed "$SERVICE_NAME" 2>/dev/null || true
    for i in $(seq 1 20); do
      if ! ss -lntp | grep -q ":${PORT}"; then
        exit 0
      fi
      sleep 0.2
    done

    pids="$({
      ss -lntp | grep ":${PORT}" | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p'
      pgrep -f "$APP_DLL_PGREP" || true
    } | sort -u || true)"
    if [ -n "$pids" ]; then
      echo "kill 端口 ${PORT} 进程：$pids"
      kill $pids || true
      sleep 1
    fi

    if ss -lntp | grep -q ":${PORT}"; then
      pids="$({
        ss -lntp | grep ":${PORT}" | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p'
        pgrep -f "$APP_DLL_PGREP" || true
      } | sort -u || true)"
      if [ -n "$pids" ]; then
        echo "kill -9 端口 ${PORT} 进程：$pids"
        kill -9 $pids || true
      fi
    fi
    ;;
  *)
    echo "用法：$0 {daemon-reload|enable|start|stop|restart|status|is-active|logs|port-info|port-in-use|release-port}"
    exit 2
    ;;
esac
