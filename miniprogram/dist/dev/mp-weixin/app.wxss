@keyframes shimmer {
0% {
    background-position: 100% 0;
}
100% {
    background-position: 0% 0;
}
}
@keyframes fadeInUp {
from {
    opacity: 0;
    transform: translateY(16rpx);
}
to {
    opacity: 1;
    transform: translateY(0);
}
}
@keyframes pulseGlow {
0%, 100% {
    box-shadow: 0 8rpx 32rpx rgba(79, 110, 247, 0.18);
}
50% {
    box-shadow: 0 8rpx 48rpx rgba(124, 92, 252, 0.28);
}
}
.page-shell {
  --page-bg: radial-gradient(circle at 0% 0%, rgba(79, 110, 247, 0.06), transparent 40%), radial-gradient(circle at 100% 30%, rgba(255, 107, 107, 0.04), transparent 35%), radial-gradient(circle at 50% 100%, rgba(247, 166, 65, 0.05), transparent 40%), #f2f4f8;
  --page-bg-soft: rgba(242, 244, 248, 0.88);
  --card-bg: rgba(255, 255, 255, 0.92);
  --card-bg-strong: rgba(255, 255, 255, 0.98);
  --text-primary: #1a1d2e;
  --text-secondary: #5a5e78;
  --text-muted: #9498ae;
  --text-inverse: #ffffff;
  --border-color: rgba(79, 110, 247, 0.1);
  --shadow-color: rgba(26, 29, 46, 0.06);
  --tab-bg:
    linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.92));
  --tab-active-bg:
    linear-gradient(135deg, rgba(255,255,255,0.24), transparent 40%),
    linear-gradient(135deg, #4f6ef7 0%, #7c5cfc 60%, #a78bfa 100%);
  --button-primary-bg:
    linear-gradient(135deg, rgba(255,255,255,0.24), transparent 40%),
    linear-gradient(135deg, #4f6ef7 0%, #7c5cfc 60%, #a78bfa 100%);
  --button-primary-text: #ffffff;
  --input-bg: rgba(255, 255, 255, 0.88);
  --input-text: #1a1d2e;
  --input-placeholder: #9498ae;
  --toast-bg: rgba(26, 29, 46, 0.94);
  --toast-text: #ffffff;
  --profit-color: #ff4d5a;
  --loss-color: #12b886;
  --warning-color: #f59e0b;
  --panel-soft: rgba(242, 244, 248, 0.92);
  --control-bg: rgba(242, 244, 248, 0.96);
  --button-radius: 999rpx;
  --card-radius: 32rpx;
  --card-shadow: 0 12rpx 40rpx rgba(26, 29, 46, 0.06);
  --primary-gradient: var(--button-primary-bg);
  --secondary-gradient: linear-gradient(135deg, rgba(79,110,247,0.06), rgba(124,92,252,0.08), rgba(255,107,107,0.04));
  --accent-pink: #ff6b6b;
  --accent-purple: #7c5cfc;
  --accent-blue: #4f6ef7;
  --theme-page-bg: var(--page-bg);
  --theme-card-bg: var(--card-bg);
  --theme-card-border: var(--border-color);
  --theme-card-shadow: var(--card-shadow);
  --theme-primary-gradient: var(--button-primary-bg);
  --theme-secondary-gradient: var(--secondary-gradient);
  --theme-accent-pink: var(--accent-pink);
  --theme-accent-purple: var(--accent-purple);
  --theme-accent-blue: var(--accent-blue);
  --theme-text-main: var(--text-primary);
  --theme-text-muted: var(--text-muted);
  --theme-text-soft: var(--text-secondary);
  --theme-profit-color: var(--profit-color);
  --theme-loss-color: var(--loss-color);
  --theme-panel-soft: var(--panel-soft);
  --theme-control-bg: var(--control-bg);
  --theme-button-radius: var(--button-radius);
  --theme-card-radius: var(--card-radius);
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx calc(222rpx + env(safe-area-inset-bottom));
  background: var(--page-bg);
  color: var(--text-primary);
}
