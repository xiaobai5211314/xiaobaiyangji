.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx calc(198rpx + env(safe-area-inset-bottom));
  background: radial-gradient(circle at 18% 0%, rgba(90, 167, 255, 0.18), transparent 34%), radial-gradient(circle at 88% 10%, rgba(139, 124, 246, 0.2), transparent 32%), linear-gradient(155deg, #08111f 0%, #101b38 44%, #20285f 100%);
}
.glass-card {
  background: linear-gradient(145deg, rgba(35, 52, 91, 0.62), rgba(17, 27, 52, 0.48)), rgba(24, 36, 68, 0.54);
  border: 1rpx solid rgba(191, 219, 254, 0.14);
  border-radius: 42rpx;
  box-shadow: 0 22rpx 58rpx rgba(3, 7, 18, 0.24), 0 10rpx 34rpx rgba(96, 165, 250, 0.08);
}
.primary-gradient-button {
  color: #fff;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.16), transparent 42%), linear-gradient(135deg, #5aa7ff 0%, #8b7cf6 100%);
  box-shadow: 0 14rpx 34rpx rgba(90, 167, 255, 0.24), inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
  min-height: 86rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}
.finance-number {
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-weight: 900;
  letter-spacing: 0;
  white-space: nowrap;
  word-break: keep-all;
  max-width: 100%;
  display: inline-flex;
  align-items: baseline;
  white-space: nowrap;
  word-break: keep-all;
  overflow: hidden;
  text-overflow: ellipsis;
}
.profit-text {
  color: #ff6b6b;
}
.loss-text {
  color: #2dd4bf;
}
.section-title {
  color: #f8fafc;
  font-size: 32rpx;
  font-weight: 900;
}
.muted-text {
  color: #91a4c2;
  font-size: 24rpx;
}
.safe-tabbar-space {
  height: calc(184rpx + env(safe-area-inset-bottom));
}
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 8rpx 2rpx 2rpx;
}
.page-title {
  display: block;
  color: #f8fafc;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.1;
}
.page-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #91a4c2;
  font-size: 24rpx;
}
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}
.stat-card {
  min-height: 146rpx;
  box-sizing: border-box;
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 14rpx;
}
.stat-label {
  color: #91a4c2;
  font-size: 22rpx;
}
.stat-value {
  color: #f8fafc;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #dce9ff;
  background: rgba(90, 167, 255, 0.12);
  border: 1rpx solid rgba(191, 219, 254, 0.14);
  font-size: 22rpx;
  font-weight: 800;
}
.empty-card {
  padding: 46rpx 30rpx;
  color: #91a4c2;
  text-align: center;
  font-size: 25rpx;
}
page {
  min-height: 100%;
  background: radial-gradient(circle at 18% 0%, rgba(90, 167, 255, 0.18), transparent 34%), radial-gradient(circle at 88% 10%, rgba(139, 124, 246, 0.2), transparent 32%), linear-gradient(155deg, #08111f 0%, #101b38 44%, #20285f 100%);
  color: #f8fafc;
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}
.page {
  min-height: 100vh;
  box-sizing: border-box;
  color: #f8fafc;
}
button {
  border: 0;
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}
button::after {
  border: 0;
}
input {
  color: #f8fafc;
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}
view,
text,
textarea {
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}