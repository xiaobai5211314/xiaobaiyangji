page {
  min-height: 100%;
  background: radial-gradient(circle at 0% 0%, rgba(79, 110, 247, 0.06), transparent 40%), radial-gradient(circle at 100% 30%, rgba(255, 107, 107, 0.04), transparent 35%), radial-gradient(circle at 50% 100%, rgba(247, 166, 65, 0.05), transparent 40%), #f2f4f8;
  color: #1a1d2e;
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}
.page {
  min-height: 100vh;
  box-sizing: border-box;
  color: #1a1d2e;
}
button {
  border: 0;
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}
button::after {
  border: 0;
}
input {
  color: #1a1d2e;
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}
view,
text,
textarea {
  font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}