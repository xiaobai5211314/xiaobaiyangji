}
.page-subtitle,
.muted-text,
.hero-subtitle,
.hero-sub,
.row-sub,
.list-subtitle,
.index-sub,
.fund-code,
.news-summary,
.profile-subtitle,
.theme-subtitle,
.account-subtitle,
