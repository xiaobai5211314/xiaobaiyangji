.glass-card {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(79, 110, 247, 0.1);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(26, 29, 46, 0.06);
  background: var(--card-bg);
  border-color: var(--border-color);
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  color: var(--text-primary);
}
.primary-gradient-button {
  color: #fff;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.24), transparent 40%), linear-gradient(135deg, #4f6ef7 0%, #7c5cfc 60%, #a78bfa 100%);
  box-shadow: 0 8rpx 32rpx rgba(79, 110, 247, 0.18), 0 0 16rpx rgba(124, 92, 252, 0.08);
  background: var(--button-primary-bg);
  border-radius: var(--button-radius);
  color: var(--button-primary-text);
  min-height: 86rpx;
  font-size: 27rpx;
  font-weight: 700;
}
.finance-number {
  font-family: "DIN Alternate", "DIN", "Microsoft YaHei", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-weight: 700;
  letter-spacing: 0;
  white-space: nowrap;
  word-break: keep-all;
  font-variant-numeric: tabular-nums;
  max-width: 100%;
  display: inline-flex;
  align-items: baseline;
  color: inherit;
}
.profit-text {
  color: var(--profit-color);
}
.loss-text {
  color: var(--loss-color);
}
.section-title {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 700;
}
.muted-text {
  color: var(--text-muted);
  font-size: 24rpx;
}
.safe-tabbar-space {
  height: calc(208rpx + env(safe-area-inset-bottom));
}
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 8rpx 2rpx 18rpx;
}
.page-title {
  display: block;
  color: var(--text-primary);
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.1;
}
.page-subtitle {
  display: block;
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
.stat-card {
  min-height: 146rpx;
  box-sizing: border-box;
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 14rpx;
}
.stat-label {
  color: var(--text-muted);
  font-size: 22rpx;
}
.stat-value {
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--brand-blue);
  background: rgba(79, 110, 247, 0.08);
  border: 1rpx solid rgba(79, 110, 247, 0.1);
  font-size: 22rpx;
  font-weight: 700;
}
.empty-card {
  padding: 60rpx 30rpx;
  color: var(--text-muted);
  text-align: center;
  font-size: 25rpx;
}
.notice-text {
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.55;
  -webkit-user-select: none;
     -moz-user-select: none;
          user-select: none;
}
.input,
input,
textarea {
  color: var(--input-text);
  background: var(--input-bg);
}
input::-moz-placeholder, textarea::-moz-placeholder {
  color: var(--input-placeholder);
}
.input-placeholder,
input::placeholder,
textarea::placeholder {
  color: var(--input-placeholder);
}
.hero-card,
.action-card,
.feature-card,
.rank-card,
.fund-card,
.stock-card,
.board-card,
.index-card,
.news-card,
.overview-card,
.calendar-card,
.detail-card,
.login-card,
.profile-card,
.theme-panel,
.asset-switch,
.switch-card,
.notice-card,
.list-head {
