+
+                const toNullableNumber = (value) => {
+                    if (value === null || value === undefined || value === '') return null;
+                    const n = Number(String(value).replace(/,/g, '').replace('%', ''));
+                    return Number.isFinite(n) ? n : null;
+                };
+
+                const recalculateStockOcrItem = (item) => {
+                    const shares = toNullableNumber(item.shares);
+                    const costPrice = toNullableNumber(item.costPrice);
+                    const marketValue = toNullableNumber(item.marketValue);
+                    if (shares !== null && costPrice !== null) {
+                        item.costAmount = Number((shares * costPrice).toFixed(2));
+                    }
+                    const costAmount = toNullableNumber(item.costAmount);
+                    if (marketValue !== null && costAmount !== null) {
+                        item.floatingProfit = Number((marketValue - costAmount).toFixed(2));
+                        item.floatingProfitRate = costAmount > 0 ? Number(((item.floatingProfit / costAmount) * 100).toFixed(4)) : item.floatingProfitRate;
+                    }
+                    return item;
+                };
+
+                const normalizeStockOcrPreviewItem = (x) => {
+                    const item = {
+                        ...x,
+                        action: x.action || 'holding',
+                        shares: toNullableNumber(x.shares),
+                        costPrice: toNullableNumber(x.costPrice),
+                        costAmount: toNullableNumber(x.costAmount),
+                        marketValue: toNullableNumber(x.marketValue),
+                        floatingProfit: toNullableNumber(x.floatingProfit),
+                        floatingProfitRate: toNullableNumber(x.floatingProfitRate)
+                    };
+                    return recalculateStockOcrItem(item);
+                };
+
+                const formatOcrNumber = (value, digits = 2) => {
+                    const n = toNullableNumber(value);
+                    return n === null ? '—' : n.toFixed(digits);
+                };
+
+                const signedOcrNumber = (value, digits = 2) => {
+                    const n = toNullableNumber(value);
+                    if (n === null) return '—';
+                    return `${n >= 0 ? '+' : ''}${n.toFixed(digits)}`;
+                };
+
+                const profitColor = (value) => {
+                    const n = toNullableNumber(value);
+                    if (n === null) return {};
+                    return { color: n >= 0 ? '#ff4d4f' : '#10b981' };
+                };
